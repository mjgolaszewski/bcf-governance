{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "build_plan_mandate",
    "active_phase",
    "hotfix_lane",
    "operator_requirements_choices_disambiguations",
    "active_delivery_priorities",
    "release_trains",
    "release_readiness",
    "definition_of_ready_before_execution"
  ],
  "properties": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "id", "version", "generated_at_utc", "status", "path"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "generated_at_utc": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "build_plan_mandate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "required_fields", "completeness_standard"],
      "properties": {
        "format": { "type": "string", "minLength": 1 },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "completeness_standard": { "type": "string", "minLength": 1 }
      }
    },
    "active_phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "build_block",
        "plan",
        "workitems",
        "log",
        "memory",
        "spec",
        "build_plan",
        "lifecycle_status",
        "owner",
        "validation_commands"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "build_block": { "type": "string", "minLength": 1 },
        "plan": { "type": "string", "minLength": 1 },
        "workitems": { "type": "string", "minLength": 1 },
        "log": { "type": "string", "minLength": 1 },
        "memory": { "type": "string", "minLength": 1 },
        "spec": { "type": "string", "minLength": 1 },
        "build_plan": { "type": "string", "minLength": 1 },
        "lifecycle_status": {
          "type": "string",
          "enum": ["planned", "active", "blocked", "paused", "completed", "verified", "closed", "abandoned"]
        },
        "owner": { "type": "string", "minLength": 1 },
        "blocked_reason": { "type": "string", "minLength": 1 },
        "unblock_condition": { "type": "string", "minLength": 1 },
        "paused_reason": { "type": "string", "minLength": 1 },
        "resume_condition": { "type": "string", "minLength": 1 },
        "abandonment_reason": { "type": "string", "minLength": 1 },
        "validation_commands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "lifecycle_status": { "const": "blocked" } }, "required": ["lifecycle_status"] },
          "then": { "required": ["blocked_reason", "unblock_condition"] }
        },
        {
          "if": { "properties": { "lifecycle_status": { "const": "paused" } }, "required": ["lifecycle_status"] },
          "then": { "required": ["paused_reason", "resume_condition"] }
        },
        {
          "if": { "properties": { "lifecycle_status": { "const": "abandoned" } }, "required": ["lifecycle_status"] },
          "then": { "required": ["abandonment_reason"] }
        }
      ]
    },
    "hotfix_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scaffold_script", "default_mode", "modes", "open_records", "remediation_history"],
      "properties": {
        "scaffold_script": { "type": "string", "minLength": 1 },
        "default_mode": { "type": "string", "enum": ["lite", "full"] },
        "modes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["lite", "full"],
          "properties": {
            "lite": {
              "type": "object",
              "additionalProperties": false,
              "required": ["allowed_when"],
              "properties": {
                "allowed_when": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                }
              }
            },
            "full": {
              "type": "object",
              "additionalProperties": false,
              "required": ["required_when"],
              "properties": {
                "required_when": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "open_records": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "mode",
              "status",
              "triggered_by_commits",
              "failing_workflows",
              "root_cause",
              "remediated_in_phase",
              "hotfix_log",
              "canonical_artifacts"
            ],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "mode": { "type": "string", "enum": ["lite", "full"] },
              "status": { "type": "string", "minLength": 1 },
              "triggered_by_commits": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "failing_workflows": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "root_cause": { "type": "string", "minLength": 1 },
              "remediated_in_phase": { "type": "string", "minLength": 1 },
              "hotfix_log": { "type": "string", "minLength": 1 },
              "canonical_artifacts": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "allOf": [
              {
                "if": { "properties": { "mode": { "const": "lite" } }, "required": ["mode"] },
                "then": { "properties": { "triggered_by_commits": { "maxItems": 1 } } }
              }
            ]
          }
        },
        "remediation_history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "mode",
              "recorded_at_utc",
              "action",
              "remediated_in_phase",
              "hotfix_log",
              "canonical_artifacts",
              "local_validation"
            ],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "mode": { "type": "string", "enum": ["lite", "full"] },
              "recorded_at_utc": { "type": "string", "minLength": 1 },
              "action": { "type": "string", "minLength": 1 },
              "remediated_in_phase": { "type": "string", "minLength": 1 },
              "hotfix_log": { "type": "string", "minLength": 1 },
              "canonical_artifacts": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "local_validation": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "remote_validation_completed": {
                "type": "object",
                "additionalProperties": false,
                "required": ["commit", "workflows"],
                "properties": {
                  "commit": { "type": "string", "minLength": 1 },
                  "workflows": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "operator_requirements_choices_disambiguations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "statement"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 }
        }
      }
    },
    "active_delivery_priorities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_tranche"],
      "properties": {
        "current_tranche": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "release_trains": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_version", "status", "focus"],
        "properties": {
          "target_version": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "focus": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "release_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "validating_command"],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "validating_command": { "type": "string", "minLength": 1 }
      }
    },
    "definition_of_ready_before_execution": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
