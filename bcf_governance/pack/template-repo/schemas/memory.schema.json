{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "regression_shield",
    "stable_decisions",
    "memory_retention_policy",
    "environment_facts",
    "known_constraints",
    "reusable_commands",
    "references"
  ],
  "properties": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "id", "version", "generated_at_utc", "status", "path"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "generated_at_utc": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "regression_shield": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purpose", "invariants"],
      "properties": {
        "purpose": { "type": "string", "minLength": 1 },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stable_decisions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_repo_root",
        "canonical_governance_guide",
        "canonical_product_spec",
        "canonical_build_plan",
        "canonical_active_phase_ledger",
        "canonical_phase_log_root",
        "code_roots",
        "delivery_architecture",
        "governance_process"
      ],
      "properties": {
        "canonical_repo_root": { "type": "string", "minLength": 1 },
        "canonical_governance_guide": { "type": "string", "minLength": 1 },
        "canonical_product_spec": { "type": "string", "minLength": 1 },
        "canonical_build_plan": { "type": "string", "minLength": 1 },
        "canonical_active_phase_ledger": { "type": "string", "minLength": 1 },
        "canonical_phase_log_root": { "type": "string", "minLength": 1 },
        "code_roots": {
          "type": "object",
          "additionalProperties": false,
          "required": ["backend", "frontend"],
          "properties": {
            "backend": { "type": "string", "minLength": 1 },
            "frontend": { "type": "string", "minLength": 1 }
          }
        },
        "delivery_architecture": {
          "type": "object",
          "additionalProperties": false,
          "required": ["backend", "frontend", "data", "observability"],
          "properties": {
            "backend": { "type": "string", "minLength": 1 },
            "frontend": { "type": "string", "minLength": 1 },
            "data": { "type": "string", "minLength": 1 },
            "observability": { "type": "string", "minLength": 1 }
          }
        },
        "governance_process": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "semantic_validator",
            "structural_schema_root",
            "hotfix_lane",
            "artifact_ownership",
            "phase_rollover",
            "build_artifact_convention"
          ],
          "properties": {
            "semantic_validator": { "type": "string", "minLength": 1 },
            "structural_schema_root": { "type": "string", "minLength": 1 },
            "hotfix_lane": { "type": "string", "minLength": 1 },
            "artifact_ownership": { "type": "string", "minLength": 1 },
            "phase_rollover": { "type": "string", "minLength": 1 },
            "build_artifact_convention": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "memory_retention_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_decisions",
        "environment_facts",
        "reusable_commands",
        "stale_entry_handling"
      ],
      "properties": {
        "stable_decisions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["review_frequency"],
          "properties": {
            "review_frequency": { "type": "string", "minLength": 1 }
          }
        },
        "environment_facts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["revalidate_after_days"],
          "properties": {
            "revalidate_after_days": { "type": "integer", "minimum": 1 }
          }
        },
        "reusable_commands": {
          "type": "object",
          "additionalProperties": false,
          "required": ["validate_on_release_gate"],
          "properties": {
            "validate_on_release_gate": { "type": "boolean" }
          }
        },
        "stale_entry_handling": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "environment_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_repo_state", "active_artifacts"],
      "properties": {
        "current_repo_state": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "active_artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "spec",
            "build_plan",
            "active_phase_ledger",
            "active_phase_plan",
            "active_workitem_ledger",
            "active_phase_log"
          ],
          "properties": {
            "spec": { "type": "string", "minLength": 1 },
            "build_plan": { "type": "string", "minLength": 1 },
            "active_phase_ledger": { "type": "string", "minLength": 1 },
            "active_phase_plan": { "type": "string", "minLength": 1 },
            "active_workitem_ledger": { "type": "string", "minLength": 1 },
            "active_phase_log": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "known_constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "reusable_commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "references": {
      "type": "object",
      "additionalProperties": false,
      "required": ["governance", "product", "execution"],
      "properties": {
        "governance": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "product": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "execution": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
