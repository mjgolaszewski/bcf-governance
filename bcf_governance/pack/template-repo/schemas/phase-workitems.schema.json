{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["document", "workitems"],
  "properties": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "id", "version", "generated_at_utc", "status", "path", "phase_id"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "generated_at_utc": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "phase_id": { "type": "string", "minLength": 1 }
      }
    },
    "workitems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "priority", "status", "summary", "acceptance"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
