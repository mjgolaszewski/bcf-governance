{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["document", "hotfix", "execution_evidence", "reconciliation"],
  "properties": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "id", "version", "generated_at_utc", "status", "path"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "generated_at_utc": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["planned", "completed", "verified", "closed"]
        },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "hotfix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode", "related_phase_id", "hotfix_number", "summary"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["lite", "full"] },
        "related_phase_id": { "type": "string", "minLength": 1 },
        "hotfix_number": { "type": "integer", "minimum": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "execution_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planned_commands", "executed_commands", "notes"],
      "properties": {
        "planned_commands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "executed_commands": {
          "type": "array"
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_before_closeout"],
      "properties": {
        "required_before_closeout": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
