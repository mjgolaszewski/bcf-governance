{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document",
    "phase",
    "summary",
    "workitems",
    "execution_evidence",
    "known_constraints",
    "next_work"
  ],
  "properties": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "id", "version", "generated_at_utc", "status", "path"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "generated_at_utc": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["planned", "completed", "verified", "closed"]
        },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "build_block"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "build_block": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "highlights"],
      "properties": {
        "outcome": { "type": "string", "minLength": 1 },
        "highlights": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "workitems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "summary"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "execution_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planned_commands", "executed_commands", "notes"],
      "properties": {
        "planned_commands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "executed_commands": {
          "type": "array"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "all_tickets_closed": { "type": "boolean" },
    "required_suites_green": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "ast_architecture_gates_green": { "type": "boolean" },
    "health_checks_green": { "type": "boolean" },
    "known_warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "known_constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "next_work": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "document": {
            "properties": {
              "status": { "enum": ["verified", "closed"] }
            },
            "required": ["status"]
          }
        },
        "required": ["document"]
      },
      "then": {
        "required": [
          "all_tickets_closed",
          "required_suites_green",
          "ast_architecture_gates_green",
          "health_checks_green",
          "known_warnings"
        ]
      }
    }
  ]
}
