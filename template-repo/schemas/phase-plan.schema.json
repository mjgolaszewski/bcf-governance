{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["document", "phase", "delivery_contract", "scope_lock", "verification_plan"],
  "properties": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "id", "version", "generated_at_utc", "status", "path"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "generated_at_utc": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "build_block", "planner", "date", "scope_source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "build_block": { "type": "string", "minLength": 1 },
        "planner": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "minLength": 1 },
        "scope_source": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "delivery_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tightly_scoped_deliverables",
        "parallelizable_workstreams",
        "hard_dependencies",
        "docker_first_local_runtime",
        "completeness_standard"
      ],
      "properties": {
        "tightly_scoped_deliverables": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "parallelizable_workstreams": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 }
            }
          }
        },
        "hard_dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "docker_first_local_runtime": { "type": "string", "minLength": 1 },
        "completeness_standard": { "type": "string", "minLength": 1 }
      }
    },
    "scope_lock": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["order", "statement"],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "statement": { "type": "string", "minLength": 1 }
        }
      }
    },
    "verification_plan": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
