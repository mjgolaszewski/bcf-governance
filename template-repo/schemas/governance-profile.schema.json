{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["document", "profile", "release_gate_profile"],
  "properties": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name", "id", "version", "generated_at_utc", "status", "path"],
      "properties": {
        "kind": { "type": "string", "const": "governance_profile" },
        "name": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "generated_at_utc": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected", "rationale", "available_profiles"],
      "properties": {
        "selected": { "type": "string", "enum": ["lite", "standard", "regulated"] },
        "rationale": { "type": "string", "minLength": 1 },
        "available_profiles": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "use_when", "required_artifacts"],
            "properties": {
              "name": { "type": "string", "enum": ["lite", "standard", "regulated"] },
              "use_when": { "type": "string", "minLength": 1 },
              "required_artifacts": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "release_gate_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gates"],
      "properties": {
        "gates": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target", "status", "rationale"],
            "properties": {
              "target": { "type": "string", "minLength": 1 },
              "status": {
                "type": "string",
                "enum": ["required", "optional", "deferred", "not_applicable"]
              },
              "rationale": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
